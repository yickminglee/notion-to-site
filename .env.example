# Copy to .env and fill in. NEVER commit .env — it is gitignored.
#
# Create a Notion internal integration at https://www.notion.so/profile/integrations
# Give it READ-ONLY capabilities ("Read content" only — no insert, no update).
# Then open your source page in Notion -> ... menu -> Connections -> add the integration.
# Access cascades to every child page and inline database, so you only share the parent.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Notion page the site is built from (the parent page, with or without dashes).
NOTION_PAGE_ID=00000000000000000000000000000000

# Public origin, no trailing slash. Used for canonical URLs and sitemap.xml.
DOMAIN=https://example.com
