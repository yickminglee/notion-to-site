---
import Base from '../layouts/Base.astro';
import NotionBlocks from '../components/NotionBlocks.astro';
import DatabaseSection from '../components/DatabaseSection.astro';
import Faq from '../components/Faq.astro';
import { page, visibleDatabases, inlineDatabaseIds, faqFromNotion } from '../lib/content.mjs';
import { site, faq } from '../../site.config.mjs';

const title = `${site.name} — ${site.tagline}`;
const description = `${site.tagline} Based in ${site.location}.`;

// Databases render in place inside the page body. Anything not reachable from
// the block tree still gets rendered here so no content is silently dropped.
const orphanDatabases = visibleDatabases.filter((db) => !inlineDatabaseIds.has(db.id));

/**
 * Prefer an FAQ written in Notion (toggles under an "FAQ" heading) — it already
 * renders as page content, so only its JSON-LD is emitted here. The `faq` array
 * in site.config.mjs is a fallback for sites with no FAQ in Notion; that one has
 * to be rendered too, since nothing else puts it on the page.
 */
const notionFaq = faqFromNotion(site.faqHeading ?? undefined);
const configFaq = notionFaq.length ? [] : (faq ?? []);
const faqItems = notionFaq.length ? notionFaq : configFaq;

const faqSchema =
  faqItems.length > 0
    ? [{
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqItems.map((item) => ({
          '@type': 'Question',
          name: item.q,
          acceptedAnswer: { '@type': 'Answer', text: item.a },
        })),
      }]
    : [];
---

<Base title={title} description={description} image={page.cover} schemas={faqSchema}>
  <article class:list={['page', page.cover && 'page--covered']}>
    {page.cover && <img class="page__cover" src={page.cover} alt="" fetchpriority="high" />}

    {page.icon && (
      String(page.icon).startsWith('/') || String(page.icon).startsWith('http') ? (
        <img class="page__icon" src={page.icon} alt="" width="78" height="78" />
      ) : (
        <span class="page__icon page__icon--emoji" aria-hidden="true">{page.icon}</span>
      )
    )}

    <h1 class="page__title">{site.name}</h1>
    <p class="page__tagline">{site.tagline}</p>

    <div class="page__body">
      <NotionBlocks blocks={page.blocks} />
    </div>

    {orphanDatabases.map((db) => <DatabaseSection db={db} />)}

    <Faq items={configFaq} />
  </article>
</Base>
