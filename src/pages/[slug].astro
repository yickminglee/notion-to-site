---
/**
 * One page per database row and per Notion sub-page, at a clean
 * keyword-friendly URL.
 */
import Base from '../layouts/Base.astro';
import NotionBlocks from '../components/NotionBlocks.astro';
import { routableRows, childPages, excerpt, faqFromBlocks, faqSchema } from '../lib/content.mjs';
import { site } from '../../site.config.mjs';

export function getStaticPaths() {
  return [
    ...routableRows.map((row) => ({
      params: { slug: row.slug },
      props: { entry: row, kind: 'row' },
    })),
    ...childPages.map((sub) => ({
      params: { slug: sub.slug },
      props: { entry: sub, kind: 'subpage' },
    })),
  ];
}

const { entry, kind } = Astro.props;

// Specific service name in the title beats a generic one for search and citation.
const title = `${entry.title} — ${site.name}`;
const description =
  excerpt(entry.blocks, 155) || `${entry.title} in ${site.location}. ${site.tagline}`;

/**
 * A database row is a service offering; a sub-page is supporting material
 * (policies, guides) and should not claim to be one.
 */
const serviceSchema =
  kind === 'row'
    ? [{
        '@context': 'https://schema.org',
        '@type': 'Service',
        name: entry.title,
        serviceType: entry.title,
        areaServed: { '@type': 'Place', name: site.location },
        provider: { '@type': site.schemaType, name: site.name },
      }]
    : [];

/**
 * A long guide often carries its own FAQ. It renders as ordinary page content
 * either way; reading it a second time only adds the structured data, on the
 * page the questions actually appear on.
 */
const schemas = [
  ...serviceSchema,
  ...faqSchema(faqFromBlocks(entry.blocks, site.faqHeading ?? undefined)),
];

const tags =
  kind === 'row'
    ? Object.entries(entry.properties ?? {})
        .filter(
          ([key, value]) =>
            !['is_hidden', 'view_order', 'Slug'].includes(key) &&
            typeof value === 'string' &&
            value &&
            value !== entry.title
        )
    : [];
---

<Base title={title} description={description} image={entry.cover} schemas={schemas}>
  <article class="page page--row">
    {entry.cover && <img class="page__cover" src={entry.cover} alt="" />}

    <p class="page__breadcrumb"><a href="/">← {site.name}</a></p>

    {entry.icon && (
      String(entry.icon).startsWith('/') || String(entry.icon).startsWith('http') ? (
        <img class="page__icon" src={entry.icon} alt="" width="60" height="60" />
      ) : (
        <span class="page__icon page__icon--emoji" aria-hidden="true">{entry.icon}</span>
      )
    )}

    <h1 class="page__title">{entry.title}</h1>

    {tags.length > 0 && (
      <p class="page__tags">
        {tags.map(([, value]) => <span class="db-tag">{value}</span>)}
      </p>
    )}

    <div class="page__body">
      <NotionBlocks blocks={entry.blocks} />
    </div>
  </article>
</Base>
